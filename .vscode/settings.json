{
	"prettier.enable": false,
	"files.exclude": {
        "**/*.min.*": true,
        "**/data.html": true,
        "404/**/index.html": true,
        "about/**/index.html": true,
        "android-icon*": true,
        "apple-icon*": true,
        "applets/**/index.html": true,
        "debug/**/index.html": true,
        "favicon*": true,
        "gallery/**/index.html": true,
        "home/**/index.html": true,
        "math/index.html": true,
        "ms-icon*": true,
        "scripts/mathjax/**": true,
        "scripts/three.js": true,
        "sitemap.xml": true,
        "teaching/**/index.html": true,
        "teaching/uo/342/extra/eigenfaces-demo/scripts/data.js": true,
        "teaching/uo/342/notes/9-singular-value-decompositions/scripts/data.js": true,
        "teaching/uo/342/notes/9-singular-value-decompositions/scripts/vData.js": true,
        "writing/**/index.html": true
    },
	"editor.wordWrap": "on",
	"editor.wordWrapColumn": 128,
	"editor.formatOnSave": false,
	"editor.maxTokenizationLineLength": 200000,
	"editor.autoIndent": "advanced",
	"liveServer.settings.port": 5500,
	"explorer.sortOrder": "modified",
	"files.associations": {
		"powers": "c"
	},
	"glsllint.glslifyOptions": {
		
	},
	"terminal.integrated.shellIntegration.enabled": false,
	"glsllint.additionalStageAssociations": {
		".shader": "garbo"
	},
	"glsllint.languageSettings": {

		"javascript": {
			"parser": "TSAST"
		},
		"javascriptreact": {
			"parser": "TSAST"
		},
		"typescript": {
			"parser": "TSAST"
		},
		"typescriptreact": {
			"parser": "TSAST"
		},
		"elm": {
			"parser": "REGEX",
			"patternStart": "\\[glsl",
			"patternEnd": "\\|\\]"
		}
	},
	"liveServer.settings.ignoreFiles": [
		".vscode/**",
		"**/*.scss",
		"**/*.sass",
		"**/*.ts",
		"**/*.htmdl",
		"**/index.js",
		"**/class.js",
		"**/worker.js",
		"**/data.html",
		"**/index.html",
		"**/sitemap.xml",
		"**/*.tex",
		"**/*.aux",
		"**/*.log",
		"**/*.out",
		"**/*.zip"
    ],
    "liveServer.settings.wait": 1000
}
